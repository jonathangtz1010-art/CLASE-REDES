<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SmartSense | Monitoreo de Sensores</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Fondo decorativo -->
  <div class="bg-shape shape-1"></div>
  <div class="bg-shape shape-2"></div>
  <div class="bg-grid"></div>

  <!-- Pantalla de login -->
  <section id="loginSection" class="screen active">
    <div class="login-card">
      <div class="brand-box">
        <div class="brand-icon">●</div>
        <div>
          <h1>SmartSense</h1>
          <p>Sistema de monitoreo inteligente</p>
        </div>
      </div>

      <h2>Iniciar sesión</h2>
      <p class="login-text">
        Accede al panel principal para supervisar los sensores simulados y los indicadores LED.
      </p>

      <div class="input-group">
        <label for="usuario">Usuario</label>
        <input type="text" id="usuario" placeholder="Ingresa tu usuario">
      </div>

      <div class="input-group">
        <label for="contrasena">Contraseña</label>
        <input type="password" id="contrasena" placeholder="Ingresa tu contraseña">
      </div>

      <button id="btnLogin" class="btn btn-primary">Entrar al sistema</button>
      <p id="mensajeLogin" class="mensaje-login"></p>
    </div>
  </section>

  <!-- Panel principal -->
  <section id="dashboardSection" class="screen">
    <header class="topbar">
      <div class="brand-box">
        <div class="brand-icon">●</div>
        <div>
          <h1>SmartSense Dashboard</h1>
          <p>Monitoreo virtual de sensores con indicadores LED</p>
        </div>
      </div>

      <div class="topbar-right">
        <div class="time-box">
          <span>Última actualización</span>
          <strong id="horaActual">--:--:--</strong>
        </div>
        <button id="btnLogout" class="btn btn-outline">Cerrar sesión</button>
      </div>
    </header>

    <main class="dashboard">
      <!-- Panel izquierdo -->
      <section class="panel panel-main">
        <div class="panel-header">
          <h2>Área de monitoreo</h2>
          <span class="status-live">Sistema activo</span>
        </div>

        <div class="cards-grid">
          <!-- Card Humedad -->
          <article class="sensor-card">
            <div class="card-top">
              <h3>Sensor de humedad</h3>
              <span class="badge">Obligatorio</span>
            </div>

            <div class="sensor-value">
              <span id="humedadValor">45</span><small>%</small>
            </div>

            <div class="control-box">
              <label for="humedadRange">Modificar humedad</label>
              <input type="range" id="humedadRange" min="0" max="100" value="45">
            </div>

            <div class="control-box">
              <label for="humedadInput">Valor manual</label>
              <input type="number" id="humedadInput" min="0" max="100" value="45">
            </div>

            <div class="led-info">
              <div class="led led-off" id="ledHumedad"></div>
              <div>
                <p class="led-title">LED de humedad</p>
                <p id="estadoHumedad" class="led-state">Estado: Estable</p>
              </div>
            </div>
          </article>

          <!-- Card Temperatura -->
          <article class="sensor-card">
            <div class="card-top">
              <h3>Sensor de temperatura</h3>
              <span class="badge secondary">Adicional</span>
            </div>

            <div class="sensor-value">
              <span id="temperaturaValor">24</span><small>°C</small>
            </div>

            <div class="control-box">
              <label for="temperaturaRange">Modificar temperatura</label>
              <input type="range" id="temperaturaRange" min="0" max="50" value="24">
            </div>

            <div class="control-box">
              <label for="temperaturaInput">Valor manual</label>
              <input type="number" id="temperaturaInput" min="0" max="50" value="24">
            </div>

            <div class="led-info">
              <div class="led led-off" id="ledTemperatura"></div>
              <div>
                <p class="led-title">LED de temperatura</p>
                <p id="estadoTemperatura" class="led-state">Estado: Normal</p>
              </div>
            </div>
          </article>
        </div>

        <div class="action-row">
          <button id="btnAleatorio" class="btn btn-primary">Generar valores aleatorios</button>
          <button id="btnReset" class="btn btn-secondary">Restablecer valores</button>
        </div>
      </section>

      <!-- Panel derecho -->
      <aside class="panel panel-side">
        <div class="panel-header">
          <h2>Resumen del sistema</h2>
        </div>

        <div class="summary-card">
          <p class="summary-label">Estado general</p>
          <h3 id="estadoGeneral">Operación normal</h3>
          <p id="descripcionGeneral" class="summary-text">
            Los sensores se encuentran en valores adecuados.
          </p>
        </div>

        <div class="legend-card">
          <h3>Lógica de LEDs</h3>
          <div class="legend-item">
            <span class="mini-led red"></span>
            <p><strong>Rojo:</strong> condición crítica</p>
          </div>
          <div class="legend-item">
            <span class="mini-led yellow"></span>
            <p><strong>Amarillo:</strong> advertencia</p>
          </div>
          <div class="legend-item">
            <span class="mini-led green"></span>
            <p><strong>Verde:</strong> condición estable</p>
          </div>
        </div>

        <div class="logic-card">
          <h3>Condiciones aplicadas</h3>
          <ul>
            <li><strong>Humedad:</strong> menor o igual a 8% = rojo</li>
            <li><strong>Humedad:</strong> de 9% a 20% = amarillo</li>
            <li><strong>Humedad:</strong> mayor a 20% = verde</li>
            <li><strong>Temperatura:</strong> menor a 18°C = azul/verde frío</li>
            <li><strong>Temperatura:</strong> 18°C a 28°C = verde</li>
            <li><strong>Temperatura:</strong> mayor a 28°C = rojo</li>
          </ul>
        </div>
      </aside>
    </main>
  </section>

  <script src="script.js"></script>
</body>
</html>
